ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'${x:.1f}M'))

axes[1, 1].axis('off')
plt.suptitle('Vancouver Housing Insights Summary Dashboard', fontsize=15, fontweight='bold', y=1.02)
